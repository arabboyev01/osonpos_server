// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enums

enum S_Logs_Type {
  SYSTEM // System log error saved when system or related tables creation or update failed
  USER // User log error saved when user creation or update failed
  EMPLOYEE // Employee log error saved when employee creation or update failed
  PAYMENT_DEVICE // Payment device log error saved when payment device creation or update failed
  ORDER // Order log error saved when order creation or update failed
  AUTH // Authentication related logs
}

enum S_Item_Type {
  ITEM
  ITEM_GROUP
  ITEM_SUBCATEGORY
  MODIFIER
  MODIFIER_GROUP
  MODIFIER_SUBCATEGORY
}

enum T_Delivery_Type {
  TAKE_AWAY
  DELIVERY
}

enum T_Delivery_Status {
  PENDING
  SHIPPED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED_ATTEMPT
  CANCELLED
}

// Business Related

model A_User {
  id                           String  @id @default(uuid())
  login                        String  @unique
  password                     String
  full_name                    String?
  role                         String  @default("OWNER")
  business_id                  String?
  time_zone                    String  @default("Asia/Tashkent")
  public_name                  String?
  language                     String  @default("uz")
  details                      String?
  second_verification          Boolean @default(false)
  second_verification_password String?

  is_deleted Boolean  @default(false)
  dt_created DateTime @default(now())
  dt_updated DateTime @updatedAt
}

model A_Automated_Point {
  id         String   @id @default(uuid())
  name       String
  guid       String?
  is_deleted Boolean  @default(false)
  dt_created DateTime @default(now())
  dt_updated DateTime @updatedAt
}

model A_Workplace {
  id                 String   @id @default(uuid())
  name               String
  guid               String?
  automated_point_id String
  is_deleted         Boolean  @default(false)
  dt_created         DateTime @default(now())
  dt_updated         DateTime @updatedAt
}

model A_Business {
  id          String   @id @default(uuid())
  name        String
  db_name     String?
  address     String?
  phoneNumber String?
  email       String?
  is_deleted  Boolean  @default(false)
  dt_created  DateTime @default(now())
  dt_updated  DateTime @updatedAt
}

model S_Employee {
  id               String   @id @default(uuid())
  full_name        String
  guid             String?
  role_id          String   @default("0")
  password         String
  employee_address String?
  workplace_id     String?
  telegram_id      String?
  phone_number     String?
  notes            String?
  email            String?
  is_deleted       Boolean  @default(false)
  dt_created       DateTime @default(now())
  dt_updated       DateTime @updatedAt
}

model S_Employee_Role {
  id               String   @id @default(uuid())
  name             String
  access_resources String[]
  is_deleted       Boolean  @default(false)
  dt_created       DateTime @default(now())
  dt_updated       DateTime @updatedAt
}

