{
	"info": {
		"_postman_id": "osonpos-api-collection",
		"name": "OsonPOS API",
		"description": "Full API collection for OsonPOS Server, including the new POS Authentication flow.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Authentication & Users",
			"item": [
				{
					"name": "Register",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"login\": \"test_owner\",\n  \"password\": \"password123\",\n  \"businessName\": \"Test Business\",\n  \"name\": \"John Doe\",\n  \"phoneNumber\": \"+998901234567\",\n  \"address\": \"Tashkent, Uzbekistan\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/auth/register",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"register"
							]
						}
					},
					"response": []
				},
				{
					"name": "Login (Owner)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"if (response.access_token) {",
									"    pm.collectionVariables.set(\"owner_token\", response.access_token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"login\": \"test_owner\",\n  \"password\": \"password123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"login"
							]
						}
					},
					"response": []
				},
				{
					"name": "Get User Info",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/auth/user/info",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"user",
								"info"
							]
						}
					},
					"response": []
				},
				{
					"name": "POS: Fetch Workplaces",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/auth/pos/workplaces",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"pos",
								"workplaces"
							]
						},
						"description": "Step 2: After owner login, fetch workplaces using the owner token."
					},
					"response": []
				},
				{
					"name": "POS: Employee Login (Pincode)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"if (response.access_token) {",
									"    pm.collectionVariables.set(\"employee_token\", response.access_token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"workplaceId\": \"WORKPLACE_UUID_FROM_PREVIOUS_STEP\",\n  \"pincode\": \"1234\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/auth/pos/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"pos",
								"login"
							]
						},
						"description": "Step 3: Authenticate employee using workplace selection and pincode. Requires Owner Token."
					},
					"response": []
				}
			]
		},
