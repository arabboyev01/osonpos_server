{
	"info": {
		"_postman_id": "osonpos-api-collection",
		"name": "OsonPOS API",
		"description": "Full API collection for OsonPOS Server, including POS Auth and Second Verification.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Authentication & Users",
			"item": [
				{
					"name": "Register",
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"login\": \"test_owner\",\n  \"password\": \"password123\",\n  \"businessName\": \"Test Business\",\n  \"name\": \"John Doe\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] }
					}
				},
				{
					"name": "Login (Owner)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"if (response.access_token) {",
									"    pm.collectionVariables.set(\"owner_token\", response.access_token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"login\": \"test_owner\",\n  \"password\": \"password123\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
					}
				},
				{
					"name": "Verify Second Step (Login)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"if (response.access_token) {",
									"    pm.collectionVariables.set(\"owner_token\", response.access_token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"login\": \"test_owner\",\n  \"password\": \"123456\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/auth/second-verification/verify", "host": ["{{base_url}}"], "path": ["auth", "second-verification", "verify"] }
					},
					"description": "Call this if Login returns require_second_verification: true"
				},
				{
					"name": "Settings: Second Verification",
					"item": [
						{
							"name": "Enable (Turn On)",
							"request": {
								"method": "PATCH",
								"body": {
									"mode": "raw",
									"raw": "{\n  \"password\": \"123456\"\n}",
									"options": { "raw": { "language": "json" } }
								},
								"url": { "raw": "{{base_url}}/auth/user/second-verification/enable", "host": ["{{base_url}}"], "path": ["auth", "user", "second-verification", "enable"] }
							}
						},
						{
							"name": "Disable (Turn Off)",
							"request": {
								"method": "PATCH",
								"url": { "raw": "{{base_url}}/auth/user/second-verification/disable", "host": ["{{base_url}}"], "path": ["auth", "user", "second-verification", "disable"] }
							}
						},
						{
							"name": "Update Password",
							"request": {
								"method": "PATCH",
								"body": {
									"mode": "raw",
									"raw": "{\n  \"password\": \"654321\"\n}",
									"options": { "raw": { "language": "json" } }
								},
								"url": { "raw": "{{base_url}}/auth/user/second-verification/update-password", "host": ["{{base_url}}"], "path": ["auth", "user", "second-verification", "update-password"] }
							}
						}
					]
				},
				{
					"name": "POS: Fetch Workplaces",
					"request": {
						"method": "GET",
						"url": { "raw": "{{base_url}}/auth/pos/workplaces", "host": ["{{base_url}}"], "path": ["auth", "pos", "workplaces"] }
					}
				},
				{
					"name": "POS: Employee Login (Pincode)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"if (response.access_token) {",
									"    pm.collectionVariables.set(\"employee_token\", response.access_token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"workplaceId\": \"WORKPLACE_UUID\",\n  \"pincode\": \"1234\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/auth/pos/login", "host": ["{{base_url}}"], "path": ["auth", "pos", "login"] }
					}
				}
			]
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [{ "key": "token", "value": "{{owner_token}}", "type": "string" }]
	},
	"variable": [
		{ "key": "base_url", "value": "http://localhost:3000/api/v1", "type": "string" },
		{ "key": "owner_token", "value": "", "type": "string" },
		{ "key": "employee_token", "value": "", "type": "string" }
	]
}
